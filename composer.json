{
	"name": "codekandis/converters",
	"description": "`codekandis/converters` is a library providing uni- and bi-directional converter interfaces and classes.",
	"version": "dev-development",
	"keywords": [
		"php",
		"library",
		"converters",
		"interfaces",
		"classes"
	],
	"minimum-stability": "stable",
	"prefer-stable": true,
	"license": "MIT",
	"authors": [
		{
			"name": "Christian Ramelow",
			"email": "info@codekandis.net",
			"homepage": "https://codekandis.net",
			"role": "Developer"
		}
	],
	"support": {
		"email": "info@codekandis.net",
		"issues": "https://github.com/codekandis/converters/issues",
		"docs": "https://github.com/codekandis/converters/blob/master/README.md",
		"source": "https://github.com/codekandis/converters/tree/master"
	},
	"require": {
		"php": ">=8.3",
		"codekandis/regular-expressions": "^1.0.0"
	},
	"require-dev": {
		"roave/security-advisories": "dev-master",
		"codekandis/phpunit": "^5.0.0",
		"rector/rector": "^1.2.2"
	},
	"autoload": {
		"psr-4": {
			"CodeKandis\\Converters\\": [
				"src/"
			]
		}
	},
	"autoload-dev": {
		"psr-4": {
			"CodeKandis\\Converters\\Build\\": [
				"build/"
			],
			"CodeKandis\\Converters\\Tests\\": [
				"tests/"
			]
		}
	},
	"scripts": {
		"test": "/usr/bin/env php -dxdebug.mode=coverage ./vendor/phpunit/phpunit/phpunit --configuration ./build/phpunit.xml"
	}
}
